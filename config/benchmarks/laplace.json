{
  "name": "benchmark_laplace",
  "description": "Laplace pressure benchmark: static spherical droplet in periodic box. Success: |ΔP_sim - 2σ/R| / (2σ/R) < 2%.",
  "app": "droplet_generator",
  "benchmark": true,
  "geometry": {
    "type": "box",
    "nx": 64, "ny": 64, "nz": 64,
    "periodic": [true, true, true]
  },
  "initial_condition": {
    "type": "spherical_droplet",
    "center": [32, 32, 32],
    "radius_nodes": 15,
    "phi_inside": 0.0,
    "phi_outside": 1.0
  },
  "params": {
    "tau_c": 0.55,
    "tau_d": 0.55,
    "sigma": 0.001,
    "interface_width_dx": 4,
    "mobility": 0.01,
    "n_steps": 5000,
    "convergence_check_interval": 200,
    "vtk_interval": 0,
    "hdf5_interval": 0
  },
  "success_criteria": {
    "laplace_pressure_error_pct": 2.0,
    "spurious_current_max_lu": 1e-4
  },
  "fixed_params": {
    "tau_c": 0.55, "tau_d": 0.55, "sigma": 0.001,
    "interface_width_dx": 4, "mobility": 0.01,
    "n_steps": 5000, "vtk_interval": 0, "hdf5_interval": 0,
    "geometry_type": "box", "nx": 64, "ny": 64, "nz": 64
  },
  "runs": [
    { "id": "BM_Laplace", "radius_nodes": 15, "note": "ΔP error < 2%" }
  ]
}
